# ─────────────────────────────────────────────────────────────
# 윤비서 템플릿 환경변수
# 이 파일을 복사해서 `.env.local` 을 만들고 값을 채우세요.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────

# [필수] Supabase 연결 정보
# Supabase 대시보드 > Project Settings > API 에서 복사합니다.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# [필수] 로그인 이메일 도메인
# 로그인 ID 뒤에 붙는 가상 이메일 도메인입니다. (예: admin → admin@example.com)
# 그대로 두어도 됩니다.
NEXT_PUBLIC_AUTH_EMAIL_DOMAIN=example.com

# ─────────────────────────────────────────────────────────────
# 아래는 모두 [선택] 입니다. 비워두면 해당 기능만 동작하지 않을 뿐,
# 앱은 정상적으로 실행됩니다. 대부분의 키는 앱 실행 후
# [시스템설정] 화면에서 입력할 수도 있습니다.
# ─────────────────────────────────────────────────────────────

# (선택) 명함관리 OCR / 입금 AI매칭 / AI견적 - Google Gemini
# 시스템설정 화면에서 입력하는 것을 권장합니다.
# GEMINI_API_KEY=

# (선택) AI 견적/미팅 매칭 - Anthropic Claude
# ANTHROPIC_API_KEY=

# (선택) 세금계산서 발행 - Bolta (시스템설정 화면에서 입력 권장)
# BOLTA_API_KEY=
# BOLTA_CUSTOMER_KEY=
# BOLTA_WEBHOOK_SECRET=

# (선택) Slack 알림 (시스템설정 화면에서 입력 권장)
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# (선택) Cron 엔드포인트 보호 (Vercel 배포 시)
# CRON_SECRET=

# (선택) 웹훅 콜백용 앱 주소 (Vercel 배포 시)
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
